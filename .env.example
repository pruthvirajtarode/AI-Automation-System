# Environment Variables Configuration
# Copy this file to .env and fill in your values

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/ai_automation
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=ai_automation

# Redis Configuration
REDIS_URL=redis://localhost:6379

# API Keys (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# CRM Integration (GoHighLevel)
GOHIGHLEVEL_API_KEY=your_ghl_key
GOHIGHLEVEL_LOCATION_ID=your_location_id
GOHIGHLEVEL_BASE_URL=https://rest.gohighlevel.com/v1
GOHIGHLEVEL_CALENDAR_ID=your_calendar_id
GOHIGHLEVEL_PIPELINE_ID=your_pipeline_id
GOHIGHLEVEL_STAGE_ID_NEW=your_stage_id_new
GOHIGHLEVEL_STAGE_ID_BOOKED=your_stage_id_booked

# CRM Integration (Airtable)
AIRTABLE_TOKEN=your_airtable_token

# Trello Integration
TRELLO_API_KEY=your_trello_key
TRELLO_API_TOKEN=your_trello_token
TRELLO_BOARD_ID=your_board_id

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ZOHO_MAIL_API_KEY=your_zoho_key

# Calendar/Booking
GOOGLE_CALENDAR_API_KEY=your_google_calendar_key
CALENDLY_API_TOKEN=your_calendly_token

# Notifications
NOTIFICATION_EMAIL=admin@company.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Business Identity
BUSINESS_NAME=Digital Dada AI
BUSINESS_TAGLINE=Your AI Operations Agent
BUSINESS_SERVICES=Lead Automation, CRM Management, Appointment Booking
BUSINESS_HOURS=Monday-Friday 9 AM-6 PM EST
BOOKING_URL=https://calendly.com/your-link

# Admin Auth
ADMIN_EMAIL=admin@techsales.com
ADMIN_PASSWORD=Admin@12345

# n8n Workflow Automation
N8N_BASE_URL=http://89.167.85.77:5678
N8N_WEBHOOK_SECRET=your_n8n_secret
N8N_INTAKE_WEBHOOK_URL=http://89.167.85.77:5678/webhook/leads

# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=ai-automation-agent-data

# App Configuration
SECRET_KEY=your_secret_key_change_this_in_production
APP_NAME=Digital Dada AI Operations Agent
CORS_ORIGINS=http://localhost:3000,http://89.167.85.77:3000
DEPLOYMENT_ENV=docker
